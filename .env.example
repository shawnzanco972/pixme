# ----------------------------------------------------------------------
# Pixme — environment variables
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.
# ----------------------------------------------------------------------

# --- Supabase ---------------------------------------------------------
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Public anon key (safe for the browser; RLS enforces access)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key (SERVER ONLY — bypasses RLS; never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# --- iCount (payments) ------------------------------------------------
# Filled in during Phase 1.3/1.4 once the API is researched.
ICOUNT_API_TOKEN=
# Optional webhook signing secret, if iCount supports signed webhooks.
ICOUNT_WEBHOOK_SECRET=
