# ----------------------------------------------------------------------
# Pixme — environment variables
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.
# ----------------------------------------------------------------------

# --- Supabase ---------------------------------------------------------
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Public anon key (safe for the browser; RLS enforces access)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key (SERVER ONLY — bypasses RLS; never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# --- Site -------------------------------------------------------------
# Public base URL used to build checkout success + IPN callback URLs.
# e.g. https://pixme.vercel.app  (no trailing slash). Defaults to localhost:3000.
NEXT_PUBLIC_SITE_URL=

# --- iCount (payments) ------------------------------------------------
# Secret API token for server-side charge + transaction verification.
ICOUNT_API_TOKEN=
# Optional webhook signing secret, if iCount supports signed webhooks.
ICOUNT_WEBHOOK_SECRET=
# Optional override for the iCount API base URL.
ICOUNT_BASE_URL=
